@{
    ViewData["Title"] = "Quản lý sản phẩm";
}

<div class="container mt-4">
    <h2 class="mb-4 text-primary">Quản lý sản phẩm</h2>

    <div id="message" class="alert" style="display:none;"></div>

    <!-- Nút thêm sản phẩm -->
    <button type="button" class="btn btn-primary mb-3" data-toggle="modal" data-target="#sanPhamModal" onclick="clearForm()">
        Thêm sản phẩm
    </button>

    <!-- Thanh tìm kiếm -->
    <div class="input-group mb-3" style="max-width: 300px;">
        <input type="text" id="searchInput" class="form-control" placeholder="Nhập mã hoặc tên sản phẩm">
        <div class="input-group-append">
            <span class="input-group-text"><i class="fas fa-search"></i></span>
        </div>
    </div>
    <div class="mb-3" style="max-width: 300px;">
        <select id="filterMaLoai" class="form-control">
            <option value="">-- Tất cả loại sản phẩm --</option>
        </select>
    </div>

    <!-- Bảng danh sách sản phẩm -->
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-bordered table-hover mb-0" id="sanPhamTable">
                <thead class="bg-primary text-white">
                    <tr>
                        <th>Mã sản phẩm</th>
                        <th>Tên sản phẩm</th>
                        <th>Đơn vị tính</th>
                        <th>Hạn dùng</th>
                        <th>Số lượng</th>
                        <th>Đơn giá bán</th>
                        <th>Loại sản phẩm</th>
                        <th>Nhà cung cấp</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody id="sanPhamList"></tbody>
            </table>
        </div>
    </div>
    <div class="d-flex justify-content-between align-items-center mt-3">
        <small id="paginationInfo" class="text-muted"></small>
        <ul class="pagination mb-0" id="pagination"></ul>
    </div>

    <!-- Modal thêm/sửa sản phẩm -->
    <div class="modal fade" id="sanPhamModal" tabindex="-1" role="dialog" aria-labelledby="sanPhamModalLabel" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title" id="sanPhamModalLabel">Thêm/Sửa sản phẩm</h5>
                </div>
                <div class="modal-body">
                    <form id="sanPhamForm">
                        <div class="form-group">
                            <label class="font-weight-bold">Mã sản phẩm</label>
                            <input type="text" id="maSP" class="form-control" required />
                        </div>
                        <div class="form-group">
                            <label class="font-weight-bold">Tên sản phẩm</label>
                            <input type="text" id="tenSP" class="form-control" required />
                        </div>
                        <div class="form-group">
                            <label class="font-weight-bold">Đơn vị tính</label>
                            <input type="text" id="donViTinh" class="form-control" required />
                        </div>
                        <div class="form-group">
                            <label class="font-weight-bold">Hạn dùng</label>
                            <input type="date" id="hanDung" class="form-control" required />
                        </div>
                        <div class="form-group">
                            <label class="font-weight-bold">Số lượng</label>
                            <input type="number" id="soLuong" class="form-control" required />
                        </div>
                        <div class="form-group">
                            <label class="font-weight-bold">Đơn giá bán</label>
                            <input type="number" step="0.01" id="donGiaBan" class="form-control" required />
                        </div>
                        <div class="form-group">
                            <label class="font-weight-bold">Loại sản phẩm</label>
                            <select id="maLoai" class="form-control" required></select>
                        </div>
                        <div class="form-group">
                            <label class="font-weight-bold">Nhà cung cấp</label>
                            <select id="maNCC" class="form-control" required></select>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Đóng</button>
                    <button type="button" class="btn btn-primary" id="saveSanPham">Lưu</button>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
    $(document).ready(function () {
        let allSanPhams = [];
        let currentPage = 1;
        let currentKeyword = '';
        let currentMaLoai = '';
        let currentTotalPages = 1;

        loadSanPhamList(1);
        loadLoaiSanPhamDropdown();
        loadNhaCungCapDropdown();

        function formatDate(value) {
            if (!value) return '';
            const d = new Date(value);
            return isNaN(d.getTime()) ? '' : d.toLocaleDateString();
        }

        function toInputDate(value) {
            if (!value) return '';
            const d = new Date(value);
            return isNaN(d.getTime()) ? '' : d.toISOString().split('T')[0];
        }

        function safeText(value) {
            return value ?? '';
        }

        function loadSanPhamList(page) {
            currentPage = page || 1;
            $.ajax({
                url: '@Url.Action("GetProductList", "Product")',
                type: 'GET',
                data: {
                    sMaLoai: currentMaLoai,
                    sTuKhoa: currentKeyword,
                    iPage: currentPage
                },
                success: function (response) {
                    allSanPhams = response.items || [];
                    renderSanPhamList(allSanPhams, response.message);
                    renderPagination(response.currentPage || 1, response.totalPages || 1, response.totalItems || 0);
                },
                error: function (xhr, status, error) {
                    console.log("Error loading products: " + error);
                }
            });
        }

        function renderSanPhamList(data, emptyMessage) {
            var tbody = $('#sanPhamList').empty();
            if (data && data.length > 0) {
                data.forEach(function (sp) {
                    var trClass = sp.rowClass || '';
                    tbody.append(`
                        <tr class="${trClass}">
                            <td>${safeText(sp.pkSMaSp)}</td>
                            <td>${safeText(sp.sTenSp)}</td>
                            <td>${safeText(sp.sDonViTinh)}</td>
                            <td>${formatDate(sp.sHanDung)}</td>
                            <td>${sp.iSl ?? 0}</td>
                            <td>${sp.fDonGiaBan ?? 0}</td>
                            <td>${safeText(sp.loaiSanPham)}</td>
                            <td>${safeText(sp.nhaCungCap)}</td>
                            <td>
                                <button class="btn btn-warning btn-sm mr-1" onclick="editSanPham('${sp.pkSMaSp}')">Sửa</button>
                                <button class="btn btn-danger btn-sm" onclick="deleteSanPham('${sp.pkSMaSp}')">Xóa</button>
                            </td>
                        </tr>
                    `);
                });
            } else {
                tbody.append(`<tr><td colspan="9" class="text-center">${emptyMessage || 'Không tìm thấy sản phẩm'}</td></tr>`);
            }
        }

        function renderPagination(page, totalPages, totalItems) {
            currentTotalPages = totalPages;
            $('#paginationInfo').text(`Tổng: ${totalItems} sản phẩm | Trang ${page}/${totalPages}`);
            const pagination = $('#pagination').empty();

            const prevDisabled = page <= 1 ? 'disabled' : '';
            pagination.append(`<li class="page-item ${prevDisabled}"><a class="page-link" href="#" data-page="${page - 1}">Trước</a></li>`);

            const start = Math.max(1, page - 2);
            const end = Math.min(totalPages, page + 2);
            for (let i = start; i <= end; i++) {
                const active = i === page ? 'active' : '';
                pagination.append(`<li class="page-item ${active}"><a class="page-link" href="#" data-page="${i}">${i}</a></li>`);
            }

            const nextDisabled = page >= totalPages ? 'disabled' : '';
            pagination.append(`<li class="page-item ${nextDisabled}"><a class="page-link" href="#" data-page="${page + 1}">Sau</a></li>`);
        }

        $(document).on('click', '#pagination .page-link', function (e) {
            e.preventDefault();
            const p = parseInt($(this).data('page'));
            if (!isNaN(p) && p >= 1 && p <= currentTotalPages) {
                loadSanPhamList(p);
            }
        });

        $('#searchInput').on('input', function () {
            currentKeyword = $(this).val().trim();
            loadSanPhamList(1);
        });

        $('#filterMaLoai').on('change', function () {
            currentMaLoai = $(this).val();
            loadSanPhamList(1);
        });

        function loadLoaiSanPhamDropdown() {
            $.ajax({
                url: '@Url.Action("GetLoaiSanPhamDropdown", "Product")',
                type: 'GET',
                success: function (data) {
                    var select = $('#maLoai').empty();
                    select.append('<option value="">-- Chọn loại sản phẩm --</option>');

                    var filterSelect = $('#filterMaLoai').empty();
                    filterSelect.append('<option value="">-- Tất cả loại sản phẩm --</option>');

                    data.forEach(function (l) {
                        select.append(`<option value="${l.pkSMaLoai}">${l.sTenLoai}</option>`);
                        filterSelect.append(`<option value="${l.pkSMaLoai}">${l.sTenLoai}</option>`);
                    });
                }
            });
        }

        function loadNhaCungCapDropdown() {
            $.ajax({
                url: '@Url.Action("GetNhaCungCapDropdown", "Product")',
                type: 'GET',
                success: function (data) {
                    var select = $('#maNCC').empty();
                    select.append('<option value="">-- Chọn nhà cung cấp --</option>');
                    data.forEach(function (n) {
                        select.append(`<option value="${n.pkSMaNcc}">${n.sTenNcc}</option>`);
                    });
                }
            });
        }

        window.clearForm = function () {
            $('#sanPhamForm')[0].reset();
            $('#maSP').prop('disabled', false);
            $('#sanPhamModalLabel').text('Thêm sản phẩm');
        };

        $('#saveSanPham').click(function () {
            var sanPham = {
                PkSMaSp: $('#maSP').val(),
                STenSp: $('#tenSP').val(),
                SDonViTinh: $('#donViTinh').val(),
                SHanDung: $('#hanDung').val(),
                ISl: parseInt($('#soLuong').val()),
                FDonGiaBan: parseFloat($('#donGiaBan').val()),
                FkSMaLoai: $('#maLoai').val(),
                FkSMaNcc: $('#maNCC').val()
            };

            var url = $('#maSP').prop('disabled') ? '@Url.Action("EditProduct", "Product")' : '@Url.Action("AddProduct", "Product")';
            $.ajax({
                url: url,
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(sanPham),
                success: function (response) {
                    showMessage(response.success ? 'alert-success' : 'alert-danger', response.message);
                    if (response.success) {
                        $('#sanPhamModal').modal('hide');
                        loadSanPhamList(currentPage);
                        $('#searchInput').val(currentKeyword);
                    }
                }
            });
        });

        window.editSanPham = function (maSP) {
            const sp = allSanPhams.find(x => x.pkSMaSp === maSP);
            if (!sp) {
                showMessage('alert-danger', 'Không tìm thấy sản phẩm!');
                return;
            }

            $('#maSP').val(sp.pkSMaSp).prop('disabled', true);
            $('#tenSP').val(safeText(sp.sTenSp));
            $('#donViTinh').val(safeText(sp.sDonViTinh));
            $('#hanDung').val(toInputDate(sp.sHanDung));
            $('#soLuong').val(sp.iSl ?? 0);
            $('#donGiaBan').val(sp.fDonGiaBan ?? 0);
            $('#maLoai').val(sp.fkSMaLoai || '');
            $('#maNCC').val(sp.fkSMaNcc || '');
            $('#sanPhamModalLabel').text('Sửa sản phẩm');
            $('#sanPhamModal').modal('show');
        };

        window.deleteSanPham = function (maSP) {
            if (confirm('Bạn có chắc muốn xóa sản phẩm này không?')) {
                $.ajax({
                    url: '@Url.Action("DeleteProduct", "Product")',
                    type: 'POST',
                    data: { maSP: maSP },
                    success: function (response) {
                        showMessage(response.success ? 'alert-success' : 'alert-danger', response.message);
                        if (response.success) {
                            loadSanPhamList(currentPage);
                        }
                    }
                });
            }
        };

        function showMessage(className, message) {
            $('#message').removeClass('alert-success alert-danger')
                .addClass(className).text(message).show();
            setTimeout(() => $('#message').hide(), 3000);
        }

        $(document).on('click', '.close, .btn-secondary', function () {
            $('#sanPhamModal').modal('hide');
        });
    });
</script>