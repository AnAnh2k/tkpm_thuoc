@model CNPM.Services.Dtos.HoaDonViewDto

@{
    ViewData["Title"] = "Chi tiết hóa đơn #" + Model.PhieuThu.PkSMaPt;
}

<div class="container mt-4">
    <h2 class="mb-4 text-primary">Chi tiết hóa đơn #@Model.PhieuThu.PkSMaPt</h2>

    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">Thông tin hóa đơn</h4>
        </div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3 font-weight-bold">Mã hóa đơn</dt>
                <dd class="col-sm-9">@Model.PhieuThu.PkSMaPt</dd>

                <dt class="col-sm-3 font-weight-bold">Khách hàng</dt>
                <dd class="col-sm-9">@(Model.PhieuThu.FkSMaKhNavigation?.STenKh ?? "Khách vãng lai") (@Model.PhieuThu.FkSMaKhNavigation?.SSdt)</dd>

                <dt class="col-sm-3 font-weight-bold">Nhân viên lập</dt>
                <dd class="col-sm-9">@Model.PhieuThu.FkSMaNvNavigation?.SHoTen (@Model.PhieuThu.FkSMaNvNavigation?.SSdt)</dd>

                <dt class="col-sm-3 font-weight-bold">Ngày lập</dt>
                <dd class="col-sm-9">@String.Format("{0:dd/MM/yyyy HH:mm}", Model.PhieuThu.DTgLap)</dd>

                <dt class="col-sm-3 font-weight-bold">Hình thức thanh toán</dt>
                <dd class="col-sm-9">@Model.PhieuThu.SHinhThucTt</dd>

                <dt class="col-sm-3 font-weight-bold">Mã khuyến mãi</dt>
                <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.MaKhuyenMai) ? "-" : Model.MaKhuyenMai)</dd>

                <dt class="col-sm-3 font-weight-bold">Khuyến mãi (%)</dt>
                <dd class="col-sm-9">@String.Format("{0:0.##}", Model.KhuyenMaiPhanTram)%</dd>

                <dt class="col-sm-3 font-weight-bold">Loại giảm trực tiếp</dt>
                <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.LoaiGiamGia) ? "-" : Model.LoaiGiamGia)</dd>

                <dt class="col-sm-3 font-weight-bold">Giá trị giảm trực tiếp</dt>
                <dd class="col-sm-9">
                    @if (string.Equals(Model.LoaiGiamGia, "PHANTRAM", StringComparison.OrdinalIgnoreCase))
                    {
                        @String.Format("{0:0.##}%", Model.GiaTriGiamGia)
                    }
                    else if (string.Equals(Model.LoaiGiamGia, "VND", StringComparison.OrdinalIgnoreCase))
                    {
                        @String.Format("{0:N0}", Model.GiaTriGiamGia)
                    }
                    else
                    {
                        @:"-"
                    }
                </dd>
            </dl>
        </div>
    </div>

    <div class="card shadow-sm mt-3">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">Chi tiết sản phẩm</h4>
        </div>
        <div class="card-body p-0">
            <table class="table table-bordered table-hover mb-0">
                <thead class="bg-primary text-white">
                    <tr>
                        <th>Mã sản phẩm</th>
                        <th>Tên sản phẩm</th>
                        <th>Số lượng</th>
                        <th>Đơn giá</th>
                        <th>Thành tiền</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ct in Model.PhieuThu.TblCtphieuThus)
                    {
                        <tr>
                            <td>@ct.PkFkSMaSp</td>
                            <td>@(ct.PkFkSMaSpNavigation?.STenSp ?? "Không xác định")</td>
                            <td>@ct.ISl</td>
                            <td>@String.Format("{0:N0}", ct.PkFkSMaSpNavigation?.FDonGiaBan ?? 0)</td>
                            <td>@String.Format("{0:N0}", (ct.ISl ?? 0) * (ct.PkFkSMaSpNavigation?.FDonGiaBan ?? 0))</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="4" class="text-right font-weight-bold">Tạm tính</td>
                        <td>@String.Format("{0:N0}", Model.TongTienTamTinh)</td>
                    </tr>
                    <tr>
                        <td colspan="4" class="text-right">Tổng tiền giảm</td>
                        <td>-@String.Format("{0:N0}", Model.TongTienGiam)</td>
                    </tr>
                    <tr class="font-weight-bold">
                        <td colspan="4" class="text-right">Tổng thanh toán</td>
                        <td>@String.Format("{0:N0}", Model.TongThanhToan)</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>

    <div class="mt-3">
        <a href="@Url.Action("HoaDon", "Sale", new
        {
            maPT = Model.PhieuThu.PkSMaPt,
            maKhuyenMai = Model.MaKhuyenMai,
            khuyenMaiPhanTram = Model.KhuyenMaiPhanTram,
            loaiGiamGia = Model.LoaiGiamGia,
            giaTriGiamGia = Model.GiaTriGiamGia,
            tienGiamThuCong = Model.TienGiamThuCong,
            tongTienTamTinh = Model.TongTienTamTinh,
            tongTienGiam = Model.TongTienGiam,
            tongThanhToan = Model.TongThanhToan
        })" class="btn btn-secondary">Quay lại</a>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>